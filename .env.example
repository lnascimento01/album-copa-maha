APP_NAME="Álbum da Copa MAHA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ASSET_URL=
FORCE_HTTPS=false
TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=maha_copa_album
DB_USERNAME=sail
DB_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@maha.local"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

MASTER_NAME="Leandro Nascimento"
MASTER_EMAIL="lfsnascimento84@gmail.com"
MASTER_PASSWORD="password"
APP_SEED_DEMO_DATA=true

# Design template: auto | spotify | linear | default
APP_DESIGN_THEME=auto

ADMIN_NAME="Admin MAHA"
ADMIN_EMAIL="admin@maha.local"
ADMIN_PASSWORD="password"

# CD Webhook — POST /webhook/deploy com header X-Deploy-Secret: <valor>
DEPLOY_SECRET=
# URL HTTPS com token para git pull dentro do container (ex: https://ghp_TOKEN@github.com/lnascimento01/album-copa-maha.git)
DEPLOY_GIT_REMOTE=

VITE_APP_NAME="${APP_NAME}"
APP_PORT=38080
FORWARD_DB_PORT=33306
FORWARD_REDIS_PORT=36379
FORWARD_MAILPIT_PORT=31025
FORWARD_MAILPIT_DASHBOARD_PORT=38025
VITE_PORT=35173
